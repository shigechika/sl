#!/bin/bash

# sl - Steam Locomotive wrapper script
#
# Dispatches to versioned sl binaries (sl-1985, sl-2010, sl-2023, sl-2026).
# The sl-2026 version detects existing text on the terminal screen and
# begins sweeping (pushing text off via dch2) only when the train reaches it.
#
# Usage: sl [-d] [VERSION|SUBCOMMAND] [ARGS...]
#
# Options:
#   -d          Show debug info on the last line before running
#
# Subcommands:
#   capture     Dump captured screen text
#   sweep-area  Show the 7-line area where SL runs
#   clear-col   Print the column where sweeping should start
#   debug       Show detailed sweep area analysis
#   mark        Draw a visual marker at the sweep start column

##############################################################################
# Setup
##############################################################################

# Resolve symlink to find the real script location
self=$0
if [ -L "$self" ]; then
    link=$(readlink "$self")
    case "$link" in
        /*) self=$link ;;
        *)  self=$(dirname "$self")/$link ;;
    esac
fi
selfdir=$(dirname "$self")
if [ -d "$selfdir/../libexec/sl-classic" ]; then
    bindir=$selfdir/../libexec/sl-classic
else
    bindir=$selfdir
fi

##############################################################################
# Functions
##############################################################################

# Find the latest available version
resolve_latest() {
    local v
    for v in 2026 2023 2010 1985; do
        if [[ -x "$bindir/sl-$v" ]]; then
            echo "$v"
            return
        fi
    done
    echo 2023
}

# Output filter for sl-1985: add per-character delay for retro feel.
# Strips smcup/rmcup sequences to prevent alternate screen switching.
slowout() {
    PERL_BADLANG=0 perl -e '
        $|=1;
        my $delay = 0.0005;
        my %skip;
        for my $cap (qw(smcup rmcup)) {
            my $s = `tput $cap 2>/dev/null`;
            $skip{$s} = 1 if length $s;
        }
        while (sysread(STDIN, my $c, 1)) {
            if ($c eq "\e") {
                my $seq = $c;
                sysread(STDIN, $c, 1) or last;
                $seq .= $c;
                if ($c eq "[" || $c eq "(") {
                    while (sysread(STDIN, $c, 1)) {
                        $seq .= $c;
                        last if $c =~ /[A-Za-z]/;
                    }
                }
                print $seq unless $skip{$seq};
            } else {
                print $c;
                select(undef, undef, undef, $delay);
            }
        }
    '
}

##############################################################################
# Argument parsing
##############################################################################

debug_flag=0
while getopts "d" opt; do
    case "$opt" in
        d) debug_flag=1 ;;
    esac
done
shift $((OPTIND - 1))

subcmd=${1:-}
case "$subcmd" in
    2026|2023|2010|1985)
        version=$subcmd
        shift
        ;;
    capture|clear-col|debug|mark|sweep-area)
        shift
        ;;
    *)
        version=$(resolve_latest)
        ;;
esac

##############################################################################
# Subcommand dispatch (all exit here)
##############################################################################

case "$subcmd" in
    capture)
        source "$bindir/sl-screen.sh"
        get_visible_screen || { echo "Failed to capture screen text." >&2; exit 1; }
        exit 0
        ;;
    sweep-area)
        source "$bindir/sl-2026-sweep.sh"
        get_sweep_area || { echo "Failed to capture screen text." >&2; exit 1; }
        exit 0
        ;;
    clear-col)
        source "$bindir/sl-2026-sweep.sh"
        clear_col=$(calc_clear_col) || { echo "Failed to calculate clear column." >&2; exit 1; }
        printf '%s\n' "$clear_col"
        exit 0
        ;;
    debug)
        source "$bindir/sl-2026-sweep.sh"
        debug_capture_and_col
        exit $?
        ;;
    mark)
        source "$bindir/sl-2026-sweep.sh"
        clear_col=$(calc_clear_col) || { echo "Failed to calculate clear column." >&2; exit 1; }
        draw_column_marker "$clear_col"
        printf '%s\n' "$clear_col"
        exit 0
        ;;
esac

##############################################################################
# Run the selected version
##############################################################################

case "$version" in
    1985)
        # sl-1985 uses curses and needs a pty; use script(1) to provide one
        if script --help 2>&1 | grep -q -- '--command'; then
            script -qc "$bindir/sl-$version" /dev/null
        else
            script -q /dev/null "$bindir/sl-$version" "$@"
        fi | slowout
        ;;
    2026)
        # Detect the rightmost text column; default 9999 (always sweep)
        source "$bindir/sl-2026-sweep.sh"
        clear_col=9999
        if col=$(calc_clear_col); then
            ((col >= 0)) && clear_col=$col
        fi
        if ((debug_flag)); then
            get_terminal_size
            printf "========== %s %s %s %sx%s %s" \
                "${TERM:-}" "${TERM_PROGRAM:-}" "${LANG:-}" "$TERM_COLS" "$TERM_LINES" "$clear_col"
        fi
        SL_SWEEP_COL=$clear_col exec "$bindir/sl-$version" "$@"
        ;;
    *)
        exec "$bindir/sl-$version" "$@"
        ;;
esac
